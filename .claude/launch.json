{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Web (Admin + Portal)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "web",
      "autoPort": true
    },
    {
      "name": "Expo Mobile (Driver App)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081,
      "cwd": "mobile"
    }
  ]
}
