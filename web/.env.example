# logiSSign web environment example

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=https://logissign.com
NEXT_PUBLIC_BRAND_NAME=logiSSign
NEXT_PUBLIC_BRAND_DOMAIN=logissign.com

# Security
CRON_SECRET=change-me-32chars-or-more
MFA_HMAC_SECRET=change-me-hmac-secret
SESSION_IDLE_TIMEOUT_MS=1800000
RATE_LIMIT_BACKEND=supabase

# PortOne
NEXT_PUBLIC_PORTONE_STORE_ID=your-portone-store-id
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your-portone-channel-key
PORTONE_API_SECRET=your-portone-api-secret
PORTONE_V2_SECRET=your-portone-v2-secret

# SMS / Email
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER_PHONE=01012345678
RESEND_API_KEY=re_your_resend_api_key
ADMIN_PHONE=01012345678

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://public@example.ingest.sentry.io/123456
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Business defaults
NEXT_PUBLIC_CONTRACT_DAYS=30
NEXT_PUBLIC_SIGN_TOKEN_EXPIRY_DAYS=7
NEXT_PUBLIC_RENEWAL_ALERT_DAYS=60
NEXT_PUBLIC_VAT_RATE=0.1
NEXT_PUBLIC_WITHHOLDING_TAX_RATE=0.033
NEXT_PUBLIC_QR_API_URL=https://logissign.com/verify
