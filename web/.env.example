# ═══════════════════════════════════════════
# logiSSign Web — 환경변수 설정
# .env.local에 복사 후 값을 채워주세요
# ═══════════════════════════════════════════

# ── Supabase (필수) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # ⚠ 서버 전용, 절대 클라이언트 노출 금지

# ── 앱 기본 설정 (필수) ──
NEXT_PUBLIC_APP_URL=https://logissign.com                # 프로덕션 URL (CORS, CSRF 검증에 사용)
NEXT_PUBLIC_BRAND_NAME=logiSSign
NEXT_PUBLIC_BRAND_DOMAIN=logissign.com

# ── CRON 보안 (필수) ──
CRON_SECRET=your-random-secret-32chars                   # Vercel Cron + 수동 무결성 검사 인증

# ── PortOne 결제 (선택 — 결제 기능 사용 시 필수) ──
NEXT_PUBLIC_PORTONE_STORE_ID=your-store-id
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your-channel-key
PORTONE_API_SECRET=your-portone-api-secret               # ⚠ 서버 전용

# ── Solapi SMS (선택 — SMS 기능 사용 시 필수) ──
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret                 # ⚠ 서버 전용
SOLAPI_SENDER_PHONE=01012345678                          # 발신번호 (사전등록 필요)

# ── 본인인증 (선택 — 본인인증 사용 시 필수) ──
IDENTITY_PROVIDER_ID=your-provider-id
IDENTITY_API_KEY=your-identity-api-key
IDENTITY_CALLBACK_URL=https://logissign.com/portal/settings
ALLOW_DEV_IDENTITY=false                                 # true면 개발용 목업 본인인증 허용

# ── OpenAI (선택 — AI 계약서 생성 시 필수) ──
OPENAI_API_KEY=sk-your-openai-api-key                    # ⚠ 서버 전용

# ── Sentry 에러 모니터링 (선택) ──
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/12345  # 없으면 Sentry 비활성화
# SENTRY_ORG=your-org                                    # CI 소스맵 업로드용
# SENTRY_PROJECT=your-project                            # CI 소스맵 업로드용
# SENTRY_AUTH_TOKEN=your-auth-token                      # CI 소스맵 업로드용

# ── Resend 이메일 (선택 — 베타 신청 이메일 전송) ──
RESEND_API_KEY=re_your_resend_api_key                    # ⚠ 서버 전용. 없으면 콘솔 로그만

# ── 비즈니스 설정 (기본값 있음) ──
NEXT_PUBLIC_CONTRACT_DAYS=30                             # 계약서 유효기간 (일)
NEXT_PUBLIC_SIGN_TOKEN_EXPIRY_DAYS=7                     # 서명 토큰 유효기간 (일)
NEXT_PUBLIC_RENEWAL_ALERT_DAYS=60                        # 계약 만료 알림 (일 전)
NEXT_PUBLIC_VAT_RATE=0.1                                 # 부가세율
NEXT_PUBLIC_WITHHOLDING_TAX_RATE=0.033                   # 원천징수율 (3.3%)
NEXT_PUBLIC_QR_API_URL=https://logissign.com/verify      # QR 진위확인 URL
